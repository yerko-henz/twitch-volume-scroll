{
  "manifest_version": 3,
  "name": "Twitch volume scroll",
  "version": "1.1",
  "description": "Adjust video volume by using the scroll wheel over twitch.",
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://twitch.tv/*",
        "https://*.ext-twitch.tv/*"
      ],
      "js": ["script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
